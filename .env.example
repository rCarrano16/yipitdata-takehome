# Backend configuration template. Copy to .env for local development:
#   Copy-Item .env.example .env
#
# Two DATABASE_URL values exist by design:
#   - Host processes (the MCP server, pytest) reach Postgres at localhost:5432,
#     which is the value below.
#   - The backend Docker container reaches the same database at db:5432, which
#     is set in docker-compose.yml, not here.

DATABASE_URL=postgresql+psycopg://kpi:kpi@localhost:5432/kpi
TEST_DATABASE_URL=postgresql+psycopg://kpi:kpi@localhost:5432/kpi_test
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:5173
