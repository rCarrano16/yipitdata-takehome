# Frontend configuration template. Copy to .env.local for local development:
#   Copy-Item .env.example .env.local
#
# VITE_API_BASE_URL is the base URL of the backend REST API. Vite exposes
# only VITE_-prefixed variables to client code, as import.meta.env. When unset
# the API client falls back to http://localhost:8000.
VITE_API_BASE_URL=http://localhost:8000
